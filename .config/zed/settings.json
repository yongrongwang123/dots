// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "debugger": {
    "dock": "right"
  },
  "terminal": {
    "dock": "right"
  },
  "zoomed_padding": false,
  "inline_code_actions": false,
  "horizontal_scroll_margin": 0.0,
  "vertical_scroll_margin": 0.0,
  "git_panel": {
    "tree_view": true
  },
  "format_on_save": "off",
  "cursor_blink": false,
  "buffer_line_height": "standard",
  "disable_ai": true,
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  "agent": {
    "button": false,
    "favorite_models": [],
    "model_parameters": [],
  },
  "collaboration_panel": {
    "button": false,
  },
  "notification_panel": {
    "button": false,
  },
  "outline_panel": {
    "default_width": 360.0,
    "git_status": false,
    "indent_guides": {
      "show": "never",
    },
  },
  "project_panel": {
    "default_width": 360.0,
    "entry_spacing": "standard",
    "indent_guides": {
      "show": "never",
    },
    "git_status": false,
  },
  "tab_bar": {
    "show": false,
  },
  "title_bar": {
    "show_user_picture": false,
    "show_user_menu": false,
    "show_sign_in": false,
    "show_onboarding_banner": false,
    "show_project_items": false,
    "show_branch_name": false,
  },
  "status_bar": {
    "show_active_file": true,
  },
  "indent_guides": {
    "enabled": false,
  },
  "toolbar": {
    "agent_review": false,
    "selections_menu": false,
    "quick_actions": false,
    "breadcrumbs": false,
  },
  "scrollbar": {
    "show": "never",
  },
  "gutter": {
    "runnables": false,
    "folds": false,
    "min_line_number_digits": 2,
  },
  "relative_line_numbers": "enabled",
  "which_key": {
    "enabled": true,
  },
  "vim_mode": true,
  "ui_font_family": "SauceCodePro Nerd Font",
  "buffer_font_family": "SauceCodePro Nerd Font",
  "auto_update": false,
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "use_system_path_prompts": false,
  "use_system_prompts": false,
  "ui_font_size": 14.0,
  "buffer_font_size": 14.0,
  "theme": "Monokai-og",
}
